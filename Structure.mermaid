        end
    end

    %% Dependencies from arena_manager
    ArenaManagerMod --> ArenaConfigMod
    ArenaManagerMod --> AgentOrchestratorMod
    ArenaManagerMod --> SimulationEngineMod
    ArenaManagerMod --> TaskSchedulerMod
    ArenaManagerMod --> ResourceManagerMod
    ArenaManagerMod --> ViralityTrackerMod
    ArenaManagerMod --> PerformanceMonitorMod
    ArenaManagerMod --> TraceInit

    %% Dependencies from agent_orchestrator
    AgentOrchestratorMod --> ArenaConfigMod
    AgentOrchestratorMod --> TraceInit

    %% Dependencies from simulation_engine
    SimulationEngineMod --> ArenaConfigMod
    SimulationEngineMod --> TraceInit

    %% Dependencies from scheduling
    TaskSchedulerMod --> ArenaConfigMod
    TaskSchedulerMod --> TraceInit
    ResourceManagerMod --> ArenaConfigMod
    ResourceManagerMod --> TraceInit

    %% Dependencies from metrics
    ViralityTrackerMod --> TraceInit
    PerformanceMonitorMod --> ArenaConfigMod
    PerformanceMonitorMod --> TraceInit

    %% Dependencies from experiments
    ABTestingMod --> TraceInit
    EvolutionTrackerMod --> TraceInit

    %% Dependencies from examples
    FullIntegration --> ArenaManagerMod
    FullIntegration --> ArenaConfigMod
    FullSimulation --> ArenaManagerMod
    FullSimulation --> ArenaConfigMod
    SimpleSimulation --> ArenaManagerMod
    SimpleSimulation --> ArenaConfigMod

    %% Dependencies from tests
    TestArena --> ArenaManagerMod
    TestArena --> ArenaConfigMod

    %% Styling
    classDef coreStyle fill:#ff6b6b,stroke:#333,stroke-width:2px,color:#fff
    classDef configStyle fill:#ffd93d,stroke:#333,stroke-width:2px,color:#000
    classDef schedStyle fill:#4ecdc4,stroke:#333,stroke-width:2px,color:#fff
    classDef metricsStyle fill:#95e1d3,stroke:#333,stroke-width:2px,color:#000
    classDef expStyle fill:#f38181,stroke:#333,stroke-width:2px,color:#fff
    classDef logStyle fill:#dfe6e9,stroke:#333,stroke-width:2px,color:#000
    classDef exampleStyle fill:#a8e6cf,stroke:#333,stroke-width:2px,color:#000

    class ArenaManagerMod,AgentOrchestratorMod,SimulationEngineMod coreStyle
    class ArenaConfigMod,ConfigInit configStyle
    class TaskSchedulerMod,ResourceManagerMod schedStyle
    class ViralityTrackerMod,PerformanceMonitorMod metricsStyle
    class ABTestingMod,EvolutionTrackerMod expStyle
    class TraceInit,LoggerMod,ConfigMod,ContextMod,ManagerMod logStyle
    class SimpleSimulation,FullSimulation,FullIntegration,TestArena exampleStyle


%% ============================================================================
%% DIAGRAM 5: TRACE LOGGING ARCHITECTURE
%% ============================================================================
%% This diagram shows the comprehensive trace logging system structure.
%% ============================================================================

graph TB
    subgraph "Trace Logging System"
        subgraph "Core Logging Components"
            GetLogger[get_logger<br/>━━━━━━━━━━━━━━━<br/>Factory function for<br/>creating loggers]
            TraceLogger[TraceLogger<br/>━━━━━━━━━━━━━━━<br/>Custom logger with<br/>structured logging]
            LogConfig[LogConfig<br/>━━━━━━━━━━━━━━━<br/>Logging configuration<br/>settings]
        end
        
        subgraph "Context Management"
            TraceContext[TraceContext<br/>━━━━━━━━━━━━━━━<br/>Request/session<br/>context tracking]
            ContextManager[get_trace_context<br/>━━━━━━━━━━━━━━━<br/>Context retrieval]
        end
        
        subgraph "Specialized Trace Managers"
            TraceManager[TraceManager<br/>━━━━━━━━━━━━━━━<br/>Base trace manager]
            AgentTraceManager[AgentTraceManager<br/>━━━━━━━━━━━━━━━<br/>Agent-specific tracing]
            SimTraceManager[SimulationTraceManager<br/>━━━━━━━━━━━━━━━<br/>Simulation tracing]
            PerfTraceManager[PerformanceTraceManager<br/>━━━━━━━━━━━━━━━<br/>Performance tracing]
            ExpTraceManager[ExperimentTraceManager<br/>━━━━━━━━━━━━━━━<br/>Experiment tracing]
        end
    end
    
    subgraph "Log Destinations"
        subgraph "File System Structure"
            TraceDir[trace/<br/>━━━━━━━━━━━━━━━<br/>Root trace directory]
            
            ArenaLogs[arena/<br/>• manager/<br/>• orchestrator/<br/>• simulation/<br/>• scheduler/]
            
            AgentLogs[agents/<br/>• creators/<br/>• audience/<br/>• brands/<br/>• moderators/]
            
            ExpLogs[experiments/<br/>• ab_tests/<br/>• evolution/]
            
            MetricLogs[metrics/<br/>• virality/<br/>• performance/]
            
            ErrorLogs[errors/<br/>• all_errors.log<br/>• critical.log]
            
            ArchivedLogs[archived/<br/>• rotated logs<br/>• compressed]
        end
    end
    
    subgraph "Arena Components Using Logging"
        AM[ArenaManager]
        AO[AgentOrchestrator]
        SE[SimulationEngine]
        TS[TaskScheduler]
        RM[ResourceManager]
        VT[ViralityTracker]
        PM[PerformanceMonitor]
        AB[ABTestFramework]
        ET[EvolutionTracker]
    end

    %% Logging component relationships
    GetLogger --> TraceLogger
    TraceLogger --> LogConfig
    TraceLogger --> TraceContext
    TraceContext --> ContextManager
    
    TraceManager --> AgentTraceManager
    TraceManager --> SimTraceManager
    TraceManager --> PerfTraceManager
    TraceManager --> ExpTraceManager

    %% Arena components use logging
    AM --> GetLogger
    AO --> GetLogger
    SE --> GetLogger
    TS --> GetLogger
    RM --> GetLogger
    VT --> GetLogger
    PM --> GetLogger
    AB --> GetLogger
    ET --> GetLogger

    %% Loggers write to file system
    TraceLogger --> TraceDir
    TraceDir --> ArenaLogs
    TraceDir --> AgentLogs
    TraceDir --> ExpLogs
    TraceDir --> MetricLogs
    TraceDir --> ErrorLogs
    TraceDir --> ArchivedLogs

    %% Specialized trace managers write to specific locations
    AgentTraceManager --> AgentLogs
    SimTraceManager --> ArenaLogs
    PerfTraceManager --> MetricLogs
    ExpTraceManager --> ExpLogs

    classDef logCoreStyle fill:#74b9ff,stroke:#333,stroke-width:2px,color:#fff
    classDef contextStyle fill:#a29bfe,stroke:#333,stroke-width:2px,color:#fff
    classDef managerStyle fill:#fd79a8,stroke:#333,stroke-width:2px,color:#fff
    classDef fileStyle fill:#fdcb6e,stroke:#333,stroke-width:2px,color:#000
    classDef componentStyle fill:#55efc4,stroke:#333,stroke-width:2px,color:#000

    class GetLogger,TraceLogger,LogConfig logCoreStyle
    class TraceContext,ContextManager contextStyle
    class TraceManager,AgentTraceManager,SimTraceManager,PerfTraceManager,ExpTraceManager managerStyle
    class TraceDir,ArenaLogs,AgentLogs,ExpLogs,MetricLogs,ErrorLogs,ArchivedLogs fileStyle
    class AM,AO,SE,TS,RM,VT,PM,AB,ET componentStyle


